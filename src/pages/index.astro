---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const home = await getEntry('pages', 'home');
const site = await getEntry('settings', 'site');
const experiences = (await getCollection('experiences')).sort((left, right) => left.data.order - right.data.order);

if (!home || !site) {
	throw new Error('Homepage or site settings content is missing.');
}
---

<BaseLayout
	title={home.data.seo.title}
	description={home.data.seo.description}
	siteName={site.data.siteName}
	siteTagline={site.data.siteTagline}
	navigation={site.data.navigation}
	contact={site.data.contact}
	footer={site.data.footer}
>
	<main>
		<section class="section hero">
			<div class="hero__copy">
				<p class="eyebrow">{home.data.hero.eyebrow}</p>
				<h1>{home.data.hero.title}</h1>
				<p class="lead">{home.data.hero.intro}</p>
				<div class="button-row">
					<a class="button" href={home.data.hero.primaryCtaHref}>
						{home.data.hero.primaryCtaLabel}
					</a>
					<a class="button button--secondary" href={home.data.hero.secondaryCtaHref}>
						{home.data.hero.secondaryCtaLabel}
					</a>
				</div>
				<ul class="highlight-list">
					{home.data.hero.highlights.map((item) => (
						<li class="highlight-pill">
							<strong>{item.label}</strong>
							<span>{item.text}</span>
						</li>
					))}
				</ul>
			</div>
			<div class="hero__media">
				<div class="image-frame image-frame--hero">
					<img src={home.data.hero.image} alt={home.data.hero.imageAlt} loading="eager" />
				</div>
				<div class="floating-note">
					<p class="eyebrow">A gentle first step</p>
					<p>
						Tango makes more sense when someone explains the room, the rhythm, and the codes
						without rushing you.
					</p>
				</div>
			</div>
		</section>

		<section class="section section--split">
			<div>
				<p class="eyebrow">Why this approach</p>
				<h2>{home.data.intro.title}</h2>
			</div>
			<div class="intro-panel">
				<p>{home.data.intro.body}</p>
				<ul class="detail-list">
					{home.data.intro.details.map((detail) => (
						<li>{detail}</li>
					))}
				</ul>
			</div>
		</section>

		<section class="section" id="experiences">
			<div class="section-heading">
				<div>
					<p class="eyebrow">Experiences</p>
					<h2>Choose the rhythm that fits your trip</h2>
				</div>
				<p class="section-heading__note">
					Every offer below is editable in the CMS, including copy, images, pricing notes, and
					detail pages.
				</p>
			</div>
			<div class="experience-grid">
				{experiences.map((experience) => (
					<article class="experience-card">
						<div class="image-frame">
							<img src={experience.data.image} alt={experience.data.imageAlt} loading="lazy" />
						</div>
						<div class="experience-card__body">
							<p class="card-label">{experience.data.anchorLabel}</p>
							<h3>{experience.data.title}</h3>
							<p>{experience.data.summary}</p>
							<dl class="experience-meta">
								<div>
									<dt>Duration</dt>
									<dd>{experience.data.duration}</dd>
								</div>
								<div>
									<dt>Group size</dt>
									<dd>{experience.data.groupSize}</dd>
								</div>
								<div>
									<dt>Best base</dt>
									<dd>{experience.data.location}</dd>
								</div>
							</dl>
							<p class="experience-card__anchor">{experience.data.anchorText}</p>
							<a class="text-link" href={`/experiences/${experience.id}`}>
								Read the full experience
							</a>
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="section host-section" id="about">
			<div class="image-frame image-frame--portrait">
				<img src={home.data.host.image} alt={home.data.host.imageAlt} loading="lazy" />
			</div>
			<div class="host-section__copy">
				<p class="eyebrow">{home.data.host.eyebrow}</p>
				<h2>{home.data.host.title}</h2>
				<p>{home.data.host.body}</p>
				<div class="note-grid">
					{home.data.host.notes.map((item) => (
						<div class="note-card">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="section" id="process">
			<div class="section-heading">
				<div>
					<p class="eyebrow">How it works</p>
					<h2>{home.data.process.title}</h2>
				</div>
			</div>
			<div class="steps-grid">
				{home.data.process.steps.map((step, index) => (
					<article class="step-card">
						<p class="step-card__number">0{index + 1}</p>
						<h3>{step.title}</h3>
						<p>{step.text}</p>
					</article>
				))}
			</div>
		</section>

		<section class="section faq-section">
			<div class="section-heading">
				<div>
					<p class="eyebrow">FAQ</p>
					<h2>{home.data.faq.title}</h2>
				</div>
			</div>
			<div class="faq-list">
				{home.data.faq.items.map((item) => (
					<details class="faq-card">
						<summary>{item.question}</summary>
						<p>{item.answer}</p>
					</details>
				))}
			</div>
		</section>

		<section class="section contact-section" id="contact">
			<div>
				<p class="eyebrow">Contact</p>
				<h2>{home.data.contact.title}</h2>
				<p class="lead">{home.data.contact.body}</p>
				<p class="contact-note">{home.data.contact.note}</p>
			</div>
			<div class="contact-card">
				<a class="contact-link" href={`mailto:${site.data.contact.email}`}>
					<span>{site.data.contact.emailLabel}</span>
					<strong>{site.data.contact.email}</strong>
				</a>
				<a class="contact-link" href={site.data.contact.whatsappUrl} target="_blank" rel="noreferrer">
					<span>{site.data.contact.whatsappLabel}</span>
					<strong>{site.data.contact.whatsappText}</strong>
				</a>
				<a class="contact-link" href={site.data.contact.instagramUrl} target="_blank" rel="noreferrer">
					<span>{site.data.contact.instagramLabel}</span>
					<strong>{site.data.contact.instagramHandle}</strong>
				</a>
			</div>
		</section>
	</main>
</BaseLayout>
