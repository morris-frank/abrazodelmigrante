			note: 'Wir antworten auf Spanisch, Englisch oder Deutsch, damit die Planung von Anfang an leicht bleibt.',
			emailCta: 'E-Mail senden',
			whatsappCta: 'Per WhatsApp schreiben',
			instagramCta: 'Instagram öffnen',
		},
	},
} as const;
---

<BaseLayout
	title="Abrazo del migrante | Authentic milonga experience in Buenos Aires"
	description="Multilingual milonga experience in Buenos Aires in Spanish, English, and German, centered on social tango, cultural exchange, and authentic local guidance."
	siteName={site.data.siteName}
	siteTagline={site.data.siteTagline}
	navigation={site.data.navigation}
	contact={site.data.contact}
	footer={site.data.footer}
	defaultLocale={site.data.locale}
	languages={languages}
	translations={site.data.translations}
>
	<main>
		<section class="section hero">
			<div class="hero__copy">
				{languages.map((language) => {
					const copy = content[language.code as keyof typeof content];
					return (
						<div class="locale-block" data-locale={language.code}>
							<p class="eyebrow">{copy.hero.eyebrow}</p>
							<h1>{copy.hero.title}</h1>
							<p class="lead">{copy.hero.intro}</p>
							<div class="button-row">
								<a class="button" href="#contact">{copy.hero.primaryCtaLabel}</a>
								<a class="button button--secondary" href="#format">{copy.hero.secondaryCtaLabel}</a>
							</div>
							<ul class="highlight-list">
								{copy.hero.highlights.map((item) => (
									<li class="highlight-pill">
										<strong>{item.label}</strong>
										<span>{item.text}</span>
									</li>
								))}
							</ul>
						</div>
					);
				})}
			</div>
			<div class="hero__media">
				<div class="image-frame image-frame--hero">
					<img
						src="/images/placeholders/hero-watercolor.svg"
						alt="Watercolor-style illustration suggesting an intimate tango night in Buenos Aires"
						loading="eager"
					/>
				</div>
				<div class="floating-note">
					{languages.map((language) => {
						const copy = content[language.code as keyof typeof content];
						return (
							<div class="locale-block" data-locale={language.code}>
								<p class="eyebrow">{copy.hero.noteTitle}</p>
								<p>{copy.hero.noteBody}</p>
							</div>
						);
					})}
				</div>
			</div>
		</section>

		<section class="section section--split" id="philosophy">
			<div class="section-copy">
				{languages.map((language) => {
					const copy = content[language.code as keyof typeof content];
					return (
						<div class="locale-block" data-locale={language.code}>
							<p class="eyebrow">{copy.philosophy.eyebrow}</p>
							<h2>{copy.philosophy.title}</h2>
							<div class="prose-stack">
								{copy.philosophy.paragraphs.map((paragraph) => (
									<p>{paragraph}</p>
								))}
							</div>
							<blockquote class="paper-quote">{copy.philosophy.quote}</blockquote>
						</div>
					);
				})}
			</div>
			<div class="image-frame image-frame--story">
				<img src="/images/placeholders/milonga-room.svg" alt="Warm milonga room illustration" loading="lazy" />
				<div class="image-caption">
					{languages.map((language) => {
						const copy = content[language.code as keyof typeof content];
						return (
							<p class="locale-block" data-locale={language.code}>
								{copy.philosophy.caption}
							</p>
						);
					})}
				</div>
			</div>
		</section>

		<section class="section section--split section--experience" id="experience">
			<div class="image-frame image-frame--journey">
				<img
					src="/images/placeholders/journey-watercolor.svg"
					alt="Painterly route illustration for a night moving through Buenos Aires"
					loading="lazy"
				/>
			</div>
			<div class="section-copy">
				{languages.map((language) => {
					const copy = content[language.code as keyof typeof content];
					return (
						<div class="locale-block" data-locale={language.code}>
							<p class="eyebrow">{copy.experience.eyebrow}</p>
							<h2>{copy.experience.title}</h2>
							<p class="lead lead--narrow">{copy.experience.intro}</p>
							<ul class="paper-list">
								{copy.experience.items.map((item) => (
									<li>{item}</li>
								))}
							</ul>
							<div class="note-grid">
								<div class="note-card">
									<h3>{copy.experience.asideTitle}</h3>
									<p>{copy.experience.note}</p>
								</div>
								{copy.experience.audience.map((group) => (
									<div class="note-card">
										<h3>{group.title}</h3>
										<p>{group.text}</p>
									</div>
								))}
							</div>
						</div>
					);
				})}
			</div>
		</section>

		<section class="section section--split" id="format">
			<div class="section-copy">
				{languages.map((language) => {
					const copy = content[language.code as keyof typeof content];
					return (
						<div class="locale-block" data-locale={language.code}>
							<p class="eyebrow">{copy.format.eyebrow}</p>
							<h2>{copy.format.title}</h2>
							<ol class="paper-list paper-list--ordered">
								{copy.format.items.map((item) => (
									<li>{item}</li>
								))}
							</ol>
						</div>
					);
				})}
			</div>
			<div class="aside-stack">
				<div class="info-card">
					{languages.map((language) => {
						const copy = content[language.code as keyof typeof content];
						return (
							<p class="locale-block" data-locale={language.code}>
								{copy.format.caption}
							</p>
						);
					})}
				</div>
				<div class="proposal-card">
					{languages.map((language) => {
						const copy = content[language.code as keyof typeof content];
						return (
							<div class="locale-block" data-locale={language.code}>
								<p class="eyebrow">{copy.proposal.eyebrow}</p>
								<h2>{copy.proposal.title}</h2>
								<ul class="paper-list">
									{copy.proposal.items.map((item) => (
										<li>{item}</li>
									))}
								</ul>
								<p class="proposal-card__closing">{copy.proposal.closing}</p>
							</div>
						);
					})}
				</div>
			</div>
		</section>

		<section class="section faq-section">
			<div class="section-heading">
				{languages.map((language) => {
					const copy = content[language.code as keyof typeof content];
					return (
						<div class="locale-block" data-locale={language.code}>
							<p class="eyebrow">{copy.faq.eyebrow}</p>
							<h2>{copy.faq.title}</h2>
						</div>
					);
				})}
			</div>
			{languages.map((language) => {
				const copy = content[language.code as keyof typeof content];
				return (
					<div class="locale-grid faq-list" data-locale={language.code}>
						{copy.faq.items.map((item) => (
							<details class="faq-card">
								<summary>{item.question}</summary>
								<p>{item.answer}</p>
							</details>
						))}
					</div>
				);
			})}
		</section>

		<section class="section contact-section" id="contact">
			<div>
				{languages.map((language) => {
					const copy = content[language.code as keyof typeof content];
					return (
						<div class="locale-block" data-locale={language.code}>
							<p class="eyebrow">{copy.contact.eyebrow}</p>
							<h2>{copy.contact.title}</h2>
							<p class="lead lead--narrow">{copy.contact.body}</p>
							<p class="contact-note">{copy.contact.note}</p>
						</div>
					);
				})}
			</div>
			<div class="contact-card">
				{languages.map((language) => {
					const copy = content[language.code as keyof typeof content];
					return (
						<div class="locale-grid contact-actions" data-locale={language.code}>
							<a class="contact-link" href={`mailto:${site.data.contact.email}`}>
								<span>{copy.contact.emailCta}</span>
								<strong>{site.data.contact.email}</strong>
							</a>
							<a class="contact-link" href={site.data.contact.whatsappUrl} target="_blank" rel="noreferrer">
								<span>{copy.contact.whatsappCta}</span>
								<strong>{site.data.contact.whatsappText}</strong>
							</a>
							<a class="contact-link" href={site.data.contact.instagramUrl} target="_blank" rel="noreferrer">
								<span>{copy.contact.instagramCta}</span>
								<strong>{site.data.contact.instagramHandle}</strong>
							</a>
						</div>
					);
				})}
			</div>
		</section>
	</main>
</BaseLayout>
